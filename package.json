{
  "name": "@agentic-cookbook/agentic-persona-toolkit",
  "version": "0.1.0",
  "description": "Toolkit for wiring AI persona chats into apps using the official agentic registry and my-agentic-storage. Includes the React chat UI package, the theme system, and (later) a coordinator package that glues the registry + storage into the chat backend interface.",
  "license": "UNLICENSED",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/agentic-cookbook/agentic-persona-toolkit.git"
  },
  "homepage": "https://github.com/agentic-cookbook/agentic-persona-toolkit#readme",
  "bugs": {
    "url": "https://github.com/agentic-cookbook/agentic-persona-toolkit/issues"
  },
  "publishConfig": {
    "access": "restricted",
    "registry": "https://npm.pkg.github.com"
  },
  "exports": {
    "./chat": "./packages/chat/index.ts",
    "./chat/css/base.css": "./packages/chat/css/base.css",
    "./chat/css/modes/inline.css": "./packages/chat/css/modes/inline.css",
    "./chat/css/modes/three-pane.css": "./packages/chat/css/modes/three-pane.css",
    "./chat/css/modes/mobile.css": "./packages/chat/css/modes/mobile.css",
    "./chat/css/components/content-overlay.css": "./packages/chat/css/components/content-overlay.css",
    "./themes": "./packages/themes/index.ts",
    "./themes/styles/*.css": "./packages/themes/styles/*.css"
  },
  "scripts": {
    "test": "vitest run --root packages",
    "prepublishOnly": "npm test"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "jsdom": "^29.0.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.4"
  }
}
