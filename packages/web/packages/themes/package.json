{
  "name": "@agentic-persona-toolkit/themes",
  "version": "0.1.0",
  "description": "Theme manifest, ThemeStyle component, and ColorModeProvider for agentic-persona-toolkit.",
  "license": "UNLICENSED",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./colorMode": {
      "types": "./src/colorMode.tsx",
      "import": "./src/colorMode.tsx"
    },
    "./manifest": {
      "types": "./src/manifest.ts",
      "import": "./src/manifest.ts"
    },
    "./styles/*.css": "./src/styles/*.css"
  },
  "publishConfig": {
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      },
      "./colorMode": {
        "types": "./dist/colorMode.d.ts",
        "import": "./dist/colorMode.js"
      },
      "./manifest": {
        "types": "./dist/manifest.d.ts",
        "import": "./dist/manifest.js"
      },
      "./styles/*.css": "./dist/styles/*.css"
    }
  },
  "scripts": {
    "build:data": "node scripts/build-theme-data.mjs",
    "build": "pnpm run build:data && tsup && pnpm run build:types && pnpm run build:css",
    "build:types": "tsc --emitDeclarationOnly -p tsconfig.build.json",
    "build:css": "node ../../copy-css.mjs",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "esbuild-plugin-preserve-directives": "^0.0.11",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  }
}
