{
  "name": "@agentic-developer-toolkit/avatar",
  "version": "0.1.0",
  "description": "Headless avatar behavior + animation engine. A persona-agnostic `useAvatarEngine` hook that gives any SVG face reflexes (blink, idle ladder, gaze, speech) and an expression-driven pose engine over optional channels (eyes, brows, antennae, mouth, body). Driven by an `expression` prop.",
  "license": "UNLICENSED",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup && pnpm run build:types",
    "build:types": "tsc --emitDeclarationOnly -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit"
  },
  "peerDependencies": {
    "gsap": "^3.13.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "esbuild-plugin-preserve-directives": "^0.0.11",
    "gsap": "^3.13.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  }
}
